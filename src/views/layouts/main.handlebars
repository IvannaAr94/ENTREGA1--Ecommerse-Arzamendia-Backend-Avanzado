<html lang="es">
  <head>
    <meta charset="UTF-8" />

    <!-- Permite que la página se adapte correctamente a celulares y tablets -->
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- Descripción general utilizada por navegadores y buscadores -->
    <meta
      name="description"
      content="IMAtecno, ecommerce de tecnología, electrodomésticos y productos de seguridad."
    />

    <!-- El título cambia según la vista renderizada desde Express -->
    <title>{{title}}</title>

    <!-- Archivo principal de estilos publicado desde src/public -->
    <link rel="stylesheet" href="/css/styles.css" />

    <!-- Ícono que aparece en la pestaña del navegador -->
    <link rel="icon" type="image/png" href="/images/icono-imatecno.png" />
  </head>

  <body>

    <!-- =====================================================
         ENCABEZADO PRINCIPAL
         Se muestra automáticamente en todas las vistas.
         ===================================================== -->

    <header class="main-header">

      <!-- El logo funciona también como enlace hacia la página principal -->
      <a
        href="/"
        class="header-logo-link"
        aria-label="Ir a la página principal de IMAtecno"
      >
        <img
          src="/images/icono-imatecno.png"
          alt="Logo de IMAtecno"
          class="header-logo"
        />
      </a>

      <!-- Menú principal de navegación -->
      <nav aria-label="Navegación principal">

        <!-- Enlace hacia la página de inicio -->
        <a href="/">
          Home
        </a>

        <!-- Enlace hacia el catálogo con paginación -->
        <a href="/products">
          Productos
        </a>

        <!-- Enlace hacia la administración mediante WebSocket -->
        <a href="/realtimeproducts">
          Productos en tiempo real
        </a>

        <!-- Abre la respuesta JSON de la API en otra pestaña -->
        <a href="/api/products" target="_blank" rel="noopener noreferrer">
          API de productos
        </a>

      </nav>

    </header>

    <!-- =====================================================
         CONTENIDO DINÁMICO
         Handlebars inserta en este espacio la vista solicitada.
         ===================================================== -->

    <main class="container">
      {{{body}}}
    </main>

    <!-- =====================================================
         FOOTER PRINCIPAL DE IMATECNO
         Se muestra automáticamente en todas las vistas.
         ===================================================== -->

    <footer class="site-footer">

      <!-- Contenedor que distribuye las columnas del footer -->
      <div class="footer-container">

        <!-- Columna correspondiente a la marca -->
        <div class="footer-column footer-brand">

          <!-- El logo también permite regresar al inicio -->
          <a
            href="/"
            class="footer-logo-link"
            aria-label="Ir a la página principal de IMAtecno"
          >
            <img
              src="/images/icono-imatecno.png"
              alt="Logo de IMAtecno"
              class="footer-logo"
            />
          </a>

        </div>

        <!-- Columna de dirección -->
        <div class="footer-column">

          <h3>Dirección</h3>

          <p>
            Av. Siempre Luzu 1234
          </p>

          <p>
            AMBA, Buenos Aires
          </p>

        </div>

        <!-- Columna de contacto -->
        <div class="footer-column">

          <h3>Contacto</h3>

          <!-- El enlace abre automáticamente el programa de correo -->
          <p>
            <a href="mailto:contacto@imatecno.com.ar">
              contacto@imatecno.com.ar
            </a>
          </p>

        </div>

        <!-- Columna del asistente virtual -->
        <div class="footer-column">

          <h3>Asistente virtual</h3>

          <!-- El enlace abre una conversación de WhatsApp -->
          <p>
            <a
              href="https://wa.me/541128555086"
              target="_blank"
              rel="noopener noreferrer"
            >
              WhatsApp
            </a>
          </p>

          <p>
            11 2855-5086
          </p>

        </div>

        <!-- =====================================================
     REDES SOCIALES
     Cada ícono abre la red correspondiente en otra pestaña.
     ===================================================== -->

<div class="footer-column">

  <!-- Título de la sección -->
  <h3>Redes sociales</h3>

  <!-- Contenedor de los íconos sociales -->
  <div class="footer-socials">

    <!-- Enlace hacia Facebook -->
    <a
      href="https://www.facebook.com/"
      class="social-link"
      target="_blank"
      rel="noopener noreferrer"
      aria-label="Visitar Facebook de IMAtecno"
      title="Facebook"
    >
      <!-- Ícono oficial representado mediante SVG -->
      <svg
        class="social-icon"
        viewBox="0 0 24 24"
        aria-hidden="true"
      >
        <path
          d="M22 12.07C22 6.51 17.52 2 12 2S2 6.51 2 12.07C2 17.09 5.66 21.25 10.44 22v-7.03H7.9v-2.9h2.54V9.85c0-2.52 1.49-3.91 3.77-3.91 1.09 0 2.23.2 2.23.2v2.47h-1.25c-1.23 0-1.61.77-1.61 1.56v1.9h2.74l-.44 2.9h-2.3V22C18.34 21.25 22 17.09 22 12.07Z"
        />
      </svg>
    </a>

    <!-- Enlace hacia Instagram -->
    <a
      href="https://www.instagram.com/"
      class="social-link"
      target="_blank"
      rel="noopener noreferrer"
      aria-label="Visitar Instagram de IMAtecno"
      title="Instagram"
    >
      <!-- Ícono oficial representado mediante SVG -->
      <svg
        class="social-icon"
        viewBox="0 0 24 24"
        aria-hidden="true"
      >
        <path
          d="M7.8 2h8.4A5.8 5.8 0 0 1 22 7.8v8.4a5.8 5.8 0 0 1-5.8 5.8H7.8A5.8 5.8 0 0 1 2 16.2V7.8A5.8 5.8 0 0 1 7.8 2Zm-.2 2A3.6 3.6 0 0 0 4 7.6v8.8A3.6 3.6 0 0 0 7.6 20h8.8a3.6 3.6 0 0 0 3.6-3.6V7.6A3.6 3.6 0 0 0 16.4 4H7.6Zm9.65 1.5a1.25 1.25 0 1 1 0 2.5 1.25 1.25 0 0 1 0-2.5ZM12 7a5 5 0 1 1 0 10 5 5 0 0 1 0-10Zm0 2a3 3 0 1 0 0 6 3 3 0 0 0 0-6Z"
        />
      </svg>
    </a>

    <!-- Enlace hacia X -->
    <a
      href="https://x.com/"
      class="social-link"
      target="_blank"
      rel="noopener noreferrer"
      aria-label="Visitar X de IMAtecno"
      title="X"
    >
      <!-- Ícono oficial representado mediante SVG -->
      <svg
        class="social-icon"
        viewBox="0 0 24 24"
        aria-hidden="true"
      >
        <path
          d="M18.9 2H22l-6.78 7.75L23 22h-6.09l-4.77-6.24L6.68 22H3.56l7.13-8.15L3.23 2h6.24l4.31 5.7L18.9 2Zm-1.08 17.85h1.72L8.53 4.04H6.68l11.14 15.81Z"
        />
      </svg>
    </a>

  </div>

</div>
          </div>

        </div>

      </div>

      <!-- Sector inferior con los derechos reservados -->
      <div class="footer-bottom">

        <p>
          © 2026 IMAtecno · Todos los derechos reservados.
        </p>

      </div>

      <!-- Línea violeta decorativa -->
      <div class="footer-violet-line" aria-hidden="true"></div>

    </footer>

  </body>
</html>